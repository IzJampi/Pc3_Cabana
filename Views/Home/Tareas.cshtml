@{
    ViewData["Title"] = "Tareas";
}

<div class="page-header">
    <div class="ph-icon"><i class="bi bi-kanban-fill"></i></div>
    <div>
        <h2>Gestión de Tareas</h2>
        <p>Crea, edita, elimina y filtra las tareas del sistema</p>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-funnel-fill me-2 text-primary"></i>Filtros de búsqueda</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Estado</label>
                <select id="filtroEstado" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    <option>Pendiente</option>
                    <option>EnProceso</option>
                    <option>Completada</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Prioridad</label>
                <select id="filtroPrioridad" class="form-select form-select-sm">
                    <option value="">Todas</option>
                    <option>Baja</option>
                    <option>Media</option>
                    <option>Alta</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Fecha inicio</label>
                <input type="date" id="filtroFechaInicio" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Fecha fin</label>
                <input type="date" id="filtroFechaFin" class="form-control form-control-sm" />
            </div>
        </div>
        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary btn-sm px-3" onclick="cargarTareas()">
                <i class="bi bi-search me-1"></i>Buscar
            </button>
            <button class="btn btn-outline-secondary btn-sm px-3" onclick="limpiarFiltros()">
                <i class="bi bi-x-circle me-1"></i>Limpiar
            </button>
        </div>
    </div>
</div>

<div id="alerta" class="alert d-none mb-3"></div>

<!-- Barra de acciones -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <span id="contadorTareas" class="text-muted small"></span>
    <button class="btn btn-success btn-sm px-3" onclick="abrirModalCrear()">
        <i class="bi bi-plus-lg me-1"></i>Nueva Tarea
    </button>
</div>

<!-- Tabla -->
<div class="card">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>ID</th><th>Título</th><th>Descripción</th>
                    <th>Estado</th><th>Prioridad</th><th>Vencimiento</th><th>Acciones</th>
                </tr>
            </thead>
            <tbody id="tablaTareas"></tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modalTarea" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header" style="background:var(--navy);color:#fff">
                <h5 class="modal-title" id="modalTitulo"><i class="bi bi-pencil-square me-2"></i>Nueva Tarea</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div id="modalAlerta" class="alert d-none mb-3"></div>
                <input type="hidden" id="tareaId" />
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Título <span class="text-danger">*</span></label>
                    <input type="text" id="titulo" class="form-control" placeholder="Ingresa el título..." />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Descripción</label>
                    <textarea id="descripcion" class="form-control" rows="2" placeholder="Descripción opcional..."></textarea>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label small fw-semibold">Estado <span class="text-danger">*</span></label>
                        <select id="estado" class="form-select">
                            <option>Pendiente</option><option>EnProceso</option><option>Completada</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-semibold">Prioridad <span class="text-danger">*</span></label>
                        <select id="prioridad" class="form-select">
                            <option>Baja</option><option>Media</option><option>Alta</option>
                        </select>
                    </div>
                </div>
                <div class="mb-1">
                    <label class="form-label small fw-semibold">Fecha de vencimiento</label>
                    <input type="date" id="fechaVencimiento" class="form-control" />
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary btn-sm px-4" onclick="guardarTarea()">
                    <i class="bi bi-save me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const modal = new bootstrap.Modal(document.getElementById('modalTarea'));

    async function cargarTareas() {
        const estado = document.getElementById('filtroEstado').value;
        const prioridad = document.getElementById('filtroPrioridad').value;
        const fechaInicio = document.getElementById('filtroFechaInicio').value;
        const fechaFin = document.getElementById('filtroFechaFin').value;

        let url = '/api/tareas?';
        if (estado) url += `estado=${estado}&`;
        if (prioridad) url += `prioridad=${prioridad}&`;
        if (fechaInicio) url += `fechaInicio=${fechaInicio}&`;
        if (fechaFin) url += `fechaFin=${fechaFin}&`;

        try {
            const res = await fetch(url);
            if (!res.ok) { mostrarAlerta('danger', await res.text()); return; }
            const tareas = await res.json();
            renderTabla(tareas);
            document.getElementById('contadorTareas').textContent = `${tareas.length} tarea(s) encontrada(s)`;
            ocultarAlerta();
        } catch { mostrarAlerta('danger', 'Error al conectar con la API.'); }
    }

    function renderTabla(tareas) {
        const tbody = document.getElementById('tablaTareas');
        if (!tareas.length) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-inbox fs-4 d-block mb-2"></i>No hay tareas</td></tr>';
            return;
        }
        tbody.innerHTML = tareas.map(t => `
            <tr>
                <td><span class="badge bg-secondary">#${t.id}</span></td>
                <td class="fw-semibold">${t.titulo}</td>
                <td class="text-muted small">${t.descripcion ?? '—'}</td>
                <td><span class="badge ${badgeEstado(t.estado)}">${t.estado}</span></td>
                <td><span class="badge ${badgePrioridad(t.prioridad)}">${t.prioridad}</span></td>
                <td class="small">${t.fechaVencimiento ? t.fechaVencimiento.substring(0,10) : '—'}</td>
                <td>
                    <button class="btn btn-sm btn-outline-warning me-1" onclick="abrirModalEditar(${t.id})"><i class="bi bi-pencil"></i></button>
                    <button class="btn btn-sm btn-outline-danger" onclick="eliminarTarea(${t.id})"><i class="bi bi-trash"></i></button>
                </td>
            </tr>`).join('');
    }

    function badgeEstado(e) {
        return e === 'Completada' ? 'bg-success' : e === 'EnProceso' ? 'bg-warning text-dark' : 'bg-secondary';
    }
    function badgePrioridad(p) {
        return p === 'Alta' ? 'bg-danger' : p === 'Media' ? 'bg-warning text-dark' : 'bg-info text-dark';
    }

    function abrirModalCrear() {
        document.getElementById('modalTitulo').innerHTML = '<i class="bi bi-plus-circle me-2"></i>Nueva Tarea';
        document.getElementById('tareaId').value = '';
        document.getElementById('titulo').value = '';
        document.getElementById('descripcion').value = '';
        document.getElementById('estado').value = 'Pendiente';
        document.getElementById('prioridad').value = 'Media';
        document.getElementById('fechaVencimiento').value = '';
        ocultarAlertaModal();
        modal.show();
    }

    async function abrirModalEditar(id) {
        const res = await fetch(`/api/tareas/${id}`);
        if (!res.ok) { mostrarAlerta('danger', 'No se pudo cargar la tarea.'); return; }
        const t = await res.json();
        document.getElementById('modalTitulo').innerHTML = '<i class="bi bi-pencil-square me-2"></i>Editar Tarea';
        document.getElementById('tareaId').value = t.id;
        document.getElementById('titulo').value = t.titulo;
        document.getElementById('descripcion').value = t.descripcion ?? '';
        document.getElementById('estado').value = t.estado;
        document.getElementById('prioridad').value = t.prioridad;
        document.getElementById('fechaVencimiento').value = t.fechaVencimiento ? t.fechaVencimiento.substring(0,10) : '';
        ocultarAlertaModal();
        modal.show();
    }

    async function guardarTarea() {
        const id = document.getElementById('tareaId').value;
        const body = {
            titulo: document.getElementById('titulo').value,
            descripcion: document.getElementById('descripcion').value,
            estado: document.getElementById('estado').value,
            prioridad: document.getElementById('prioridad').value,
            fechaVencimiento: document.getElementById('fechaVencimiento').value || null
        };
        const res = await fetch(id ? `/api/tareas/${id}` : '/api/tareas', {
            method: id ? 'PUT' : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        if (res.ok) { modal.hide(); cargarTareas(); }
        else {
            const err = await res.json();
            const msg = Object.values(err.errors ?? {}).flat().join(' ');
            mostrarAlertaModal('danger', msg || 'Error al guardar.');
        }
    }

    async function eliminarTarea(id) {
        if (!confirm(`¿Eliminar la tarea #${id}?`)) return;
        const res = await fetch(`/api/tareas/${id}`, { method: 'DELETE' });
        if (res.ok) cargarTareas();
        else mostrarAlerta('danger', 'No se pudo eliminar.');
    }

    function limpiarFiltros() {
        ['filtroEstado','filtroPrioridad','filtroFechaInicio','filtroFechaFin'].forEach(id => document.getElementById(id).value = '');
        cargarTareas();
    }

    function mostrarAlerta(tipo, msg) { const a = document.getElementById('alerta'); a.className = `alert alert-${tipo}`; a.textContent = msg; }
    function ocultarAlerta() { document.getElementById('alerta').className = 'alert d-none'; }
    function mostrarAlertaModal(tipo, msg) { const a = document.getElementById('modalAlerta'); a.className = `alert alert-${tipo}`; a.textContent = msg; }
    function ocultarAlertaModal() { document.getElementById('modalAlerta').className = 'alert d-none'; }

    cargarTareas();
</script>
}
