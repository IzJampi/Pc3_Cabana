@{
    ViewData["Title"] = "Tareas Externas";
}

<div class="page-header">
    <div class="ph-icon"><i class="bi bi-cloud-download-fill"></i></div>
    <div>
        <h2>Tareas Externas</h2>
        <p>Datos consumidos desde <strong>jsonplaceholder.typicode.com</strong></p>
    </div>
</div>

<div class="d-flex gap-2 align-items-center mb-4">
    <button class="btn btn-primary btn-sm px-4" onclick="cargarTareas()">
        <i class="bi bi-arrow-clockwise me-1"></i>Cargar tareas
    </button>
    <div id="spinner" class="spinner-border spinner-border-sm text-primary d-none"></div>
    <span id="contadorExternas" class="text-muted small ms-1"></span>
</div>

<div id="alerta" class="alert d-none mb-3"></div>

<!-- Detalle -->
<div id="detalle" class="card mb-4 d-none border-start border-4 border-primary">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <span class="text-muted small"><i class="bi bi-info-circle me-1"></i>Detalle de tarea seleccionada</span>
                <h5 class="mt-1 mb-2" id="detTitulo"></h5>
                <div class="d-flex gap-3">
                    <span class="small text-muted">ID externo: <strong id="detId"></strong></span>
                    <span class="small">Completado: <span id="detCompletado"></span></span>
                </div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('detalle').classList.add('d-none')">
                <i class="bi bi-x"></i>
            </button>
        </div>
    </div>
</div>

<!-- Tabla -->
<div class="card">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr><th>External ID</th><th>Título</th><th>Completado</th><th>Acción</th></tr>
            </thead>
            <tbody id="tablaExternas"></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    async function cargarTareas() {
        const spinner = document.getElementById('spinner');
        spinner.classList.remove('d-none');
        document.getElementById('detalle').classList.add('d-none');

        try {
            const res = await fetch('/api/tareas-externas');
            if (!res.ok) { mostrarAlerta('danger', `Error ${res.status}: No se pudo obtener las tareas externas.`); return; }
            const tareas = await res.json();
            renderTabla(tareas);
            document.getElementById('contadorExternas').textContent = `${tareas.length} tareas cargadas`;
            ocultarAlerta();
        } catch { mostrarAlerta('danger', 'No se pudo conectar con la API.'); }
        finally { spinner.classList.add('d-none'); }
    }

    function renderTabla(tareas) {
        document.getElementById('tablaExternas').innerHTML = tareas.map(t => `
            <tr>
                <td><span class="badge bg-secondary">#${t.externalId}</span></td>
                <td>${t.titulo}</td>
                <td><span class="badge ${t.completado ? 'bg-success' : 'bg-secondary'}">${t.completado ? 'Sí' : 'No'}</span></td>
                <td><button class="btn btn-sm btn-outline-primary" onclick="verDetalle(${t.externalId})"><i class="bi bi-eye me-1"></i>Ver</button></td>
            </tr>`).join('');
    }

    async function verDetalle(id) {
        try {
            const res = await fetch(`/api/tareas-externas/${id}`);
            if (res.status === 404) { mostrarAlerta('warning', `No existe la tarea con ID ${id}.`); return; }
            if (!res.ok) { mostrarAlerta('danger', 'Error al obtener el detalle.'); return; }
            const t = await res.json();
            document.getElementById('detId').textContent = t.externalId;
            document.getElementById('detTitulo').textContent = t.titulo;
            document.getElementById('detCompletado').innerHTML = t.completado
                ? '<span class="badge bg-success">Sí</span>'
                : '<span class="badge bg-secondary">No</span>';
            document.getElementById('detalle').classList.remove('d-none');
            ocultarAlerta();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        } catch { mostrarAlerta('danger', 'No se pudo conectar con la API.'); }
    }

    function mostrarAlerta(tipo, msg) { const a = document.getElementById('alerta'); a.className = `alert alert-${tipo}`; a.textContent = msg; }
    function ocultarAlerta() { document.getElementById('alerta').className = 'alert d-none'; }
</script>
}
